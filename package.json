{
  "name": "date-todo-desktop",
  "version": "0.1.0",
  "description": "A local Windows desktop todo app organized by date.",
  "main": "out/main/index.js",
  "author": "Qianjiazheng",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm.cmd run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "electron-vite preview",
    "dist": "npm.cmd run build && electron-builder"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.local.datetodo",
    "productName": "Date Todo",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "dir"
    }
  }
}
